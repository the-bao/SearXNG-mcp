{
  "name": "searxng-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for SearXNG metasearch engine — lets AI tools search the web",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "searxng-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
